<?xml version="1.0" encoding="UTF-8"?>
<oor:component-data
  xmlns:oor="http://openoffice.org/2001/registry"
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  oor:name="Addons"
  oor:package="org.openoffice.Office">
  <node oor:name="AddonUI">
    <node oor:name="AddonMenu">
      <node oor:name="org.codex.librecompleteai.settings" oor:op="replace">
        <prop oor:name="URL" oor:type="xs:string">
          <value>vnd.sun.star.script:LibreCompleteAI.oxt|Scripts|python|writer_autocomplete.py$show_settings?language=Python&amp;location=user:uno_packages</value>
        </prop>
        <prop oor:name="Title" oor:type="xs:string">
          <value>LibreCompleteAI Settings...</value>
        </prop>
        <prop oor:name="Target" oor:type="xs:string">
          <value>_self</value>
        </prop>
      </node>
      <node oor:name="org.codex.librecompleteai.toggle" oor:op="replace">
        <prop oor:name="URL" oor:type="xs:string">
          <value>vnd.librecompleteai:toggle</value>
        </prop>
        <prop oor:name="Title" oor:type="xs:string">
          <value>Toggle LibreCompleteAI</value>
        </prop>
        <prop oor:name="Target" oor:type="xs:string">
          <value>_self</value>
        </prop>
      </node>
      <node oor:name="org.codex.librecompleteai.continuous" oor:op="replace">
        <prop oor:name="URL" oor:type="xs:string">
          <value>vnd.librecompleteai:continuous</value>
        </prop>
        <prop oor:name="Title" oor:type="xs:string">
          <value>Toggle Continuous Suggestions</value>
        </prop>
        <prop oor:name="Target" oor:type="xs:string">
          <value>_self</value>
        </prop>
      </node>
      <node oor:name="org.codex.librecompleteai.complete" oor:op="replace">
        <prop oor:name="URL" oor:type="xs:string">
          <value>vnd.librecompleteai:complete</value>
        </prop>
        <prop oor:name="Title" oor:type="xs:string">
          <value>LibreCompleteAI Complete Now</value>
        </prop>
        <prop oor:name="Target" oor:type="xs:string">
          <value>_self</value>
        </prop>
      </node>
    </node>

    <node oor:name="Images">
      <node oor:name="org.codex.librecompleteai.image.toggle" oor:op="replace">
        <prop oor:name="URL" oor:type="xs:string">
          <value>vnd.librecompleteai:toggle</value>
        </prop>
        <node oor:name="UserDefinedImages">
          <prop oor:name="ImageSmall" oor:type="xs:hexBinary">
            <value>424D7E000000000000003E000000280000001000000010000000010001000000000040000000130B0000130B00000200000000000000FFFFFF002D52A0000000000007F000000C1800001808000010000000100000001000000011C0000011C0000019C800000DD8000007F0000001C0000001C0000001C0000000000000</value>
          </prop>
          <prop oor:name="ImageBig" oor:type="xs:hexBinary">
            <value></value>
          </prop>
        </node>
      </node>
      <node oor:name="org.codex.librecompleteai.image.continuous" oor:op="replace">
        <prop oor:name="URL" oor:type="xs:string">
          <value>vnd.librecompleteai:continuous</value>
        </prop>
        <node oor:name="UserDefinedImages">
          <prop oor:name="ImageSmall" oor:type="xs:hexBinary">
            <value>424D7E000000000000003E000000280000001000000010000000010001000000000040000000130B0000130B00000200000000000000FFFFFF002D52A000000000000000000000000000000000001E7800001FF800001FFC00001BDC00001FFE00001FF800001E7800000000000000000000000000000000000000000000</value>
          </prop>
          <prop oor:name="ImageBig" oor:type="xs:hexBinary">
            <value></value>
          </prop>
        </node>
      </node>
      <node oor:name="org.codex.librecompleteai.image.complete" oor:op="replace">
        <prop oor:name="URL" oor:type="xs:string">
          <value>vnd.librecompleteai:complete</value>
        </prop>
        <node oor:name="UserDefinedImages">
          <prop oor:name="ImageSmall" oor:type="xs:hexBinary">
            <value>424D7E000000000000003E000000280000001000000010000000010001000000000040000000130B0000130B00000200000000000000FFFFFF002D52A000000000000000000000E0000020F0000020F8000020FC00003FFC00003FFC00003FFC000020F8000020F8000020FC000000080000000000000000000000000000</value>
          </prop>
          <prop oor:name="ImageBig" oor:type="xs:hexBinary">
            <value></value>
          </prop>
        </node>
      </node>
      <node oor:name="org.codex.librecompleteai.image.settings" oor:op="replace">
        <prop oor:name="URL" oor:type="xs:string">
          <value>vnd.sun.star.script:LibreCompleteAI.oxt|Scripts|python|writer_autocomplete.py$show_settings?language=Python&amp;location=user:uno_packages</value>
        </prop>
        <node oor:name="UserDefinedImages">
          <prop oor:name="ImageSmall" oor:type="xs:hexBinary">
            <value>424D7E000000000000003E000000280000001000000010000000010001000000000040000000130B0000130B00000200000000000000FFFFFF002D52A00001C0000039CE00003DDE00003FFE00001FFC00000E3800007DDF00007D5F00007DDF00000E3800001FFC00003FFE00003DDE000039CE000001C0000000000000</value>
          </prop>
          <prop oor:name="ImageBig" oor:type="xs:hexBinary">
            <value></value>
          </prop>
        </node>
      </node>
    </node>

    <node oor:name="OfficeToolbarMerging">
      <node oor:name="org.codex.librecompleteai.standardbar" oor:op="replace">
        <prop oor:name="MergeToolBar" oor:type="xs:string">
          <value>private:resource/toolbar/standardbar</value>
        </prop>
        <prop oor:name="MergePoint" oor:type="xs:string">
          <value/>
        </prop>
        <prop oor:name="MergeCommand" oor:type="xs:string">
          <value>AddLast</value>
        </prop>
        <prop oor:name="MergeFallback" oor:type="xs:string">
          <value>AddLast</value>
        </prop>
        <prop oor:name="MergeContext" oor:type="xs:string">
          <value>com.sun.star.text.TextDocument</value>
        </prop>
        <node oor:name="ToolBarItems">
          <node oor:name="separator" oor:op="replace">
            <prop oor:name="URL" oor:type="xs:string">
              <value>private:separator</value>
            </prop>
          </node>
          <node oor:name="toggle" oor:op="replace">
            <prop oor:name="URL" oor:type="xs:string">
              <value>vnd.librecompleteai:toggle</value>
            </prop>
            <prop oor:name="Title" oor:type="xs:string">
              <value xml:lang="en-US">LibreCompleteAI On/Off</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string">
              <value>_self</value>
            </prop>
            <prop oor:name="ControlType" oor:type="xs:string">
              <value>ToggleButton</value>
            </prop>
          </node>
          <node oor:name="continuous" oor:op="replace">
            <prop oor:name="URL" oor:type="xs:string">
              <value>vnd.librecompleteai:continuous</value>
            </prop>
            <prop oor:name="Title" oor:type="xs:string">
              <value xml:lang="en-US">Continuous Suggestions On/Off</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string">
              <value>_self</value>
            </prop>
            <prop oor:name="ControlType" oor:type="xs:string">
              <value>ToggleButton</value>
            </prop>
          </node>
          <node oor:name="complete" oor:op="replace">
            <prop oor:name="URL" oor:type="xs:string">
              <value>vnd.librecompleteai:complete</value>
            </prop>
            <prop oor:name="Title" oor:type="xs:string">
              <value xml:lang="en-US">Complete Now</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string">
              <value>_self</value>
            </prop>
          </node>
          <node oor:name="settings" oor:op="replace">
            <prop oor:name="URL" oor:type="xs:string">
              <value>vnd.sun.star.script:LibreCompleteAI.oxt|Scripts|python|writer_autocomplete.py$show_settings?language=Python&amp;location=user:uno_packages</value>
            </prop>
            <prop oor:name="Title" oor:type="xs:string">
              <value xml:lang="en-US">LibreCompleteAI Settings</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string">
              <value>_self</value>
            </prop>
          </node>
        </node>
      </node>
    </node>
  </node>
</oor:component-data>
